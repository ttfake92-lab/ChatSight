{
  "appId": "com.wechat-insight.app",
  "productName": "Wechat Insight",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "dist-electron/**/*"
  ],
  "mac": {
    "target": ["dmg", "zip"],
    "artifactName": "${productName}-${version}-${arch}.${ext}"
  },
  "win": {
    "target": ["nsis", "portable"],
    "artifactName": "${productName}-${version}-${arch}.${ext}"
  },
  "linux": {
    "target": ["AppImage", "deb"],
    "artifactName": "${productName}-${version}-${arch}.${ext}"
  }
}
